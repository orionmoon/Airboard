# Base de données
DB_HOST=localhost
DB_PORT=5433
DB_USER=airboard
DB_PASSWORD=airboard123
DB_NAME=airboard

# JWT
JWT_SECRET=votre-secret-jwt-ici
JWT_TOKEN_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# Mode de développement
GIN_MODE=debug

# Frontend
VITE_API_URL=http://localhost:8080

# SSO Configuration (Authentik)
SSO_ENABLED=false                        # Activer/désactiver le SSO
SSO_AUTO_PROVISION=true                   # Créer automatiquement les utilisateurs SSO
SSO_DEFAULT_ROLE=user                     # Rôle par défaut pour les nouveaux utilisateurs SSO
SSO_DEFAULT_GROUP=Common                  # Groupe par défaut pour les nouveaux utilisateurs SSO
SSO_ADMIN_GROUPS=airboard-admins          # Groupes Authentik ayant le rôle admin (séparés par des virgules)