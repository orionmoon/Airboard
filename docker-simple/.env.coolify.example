# 🚀 Variables d'environnement pour Coolify - Airboard
# Copiez ces variables dans la configuration Coolify

# ===== OBLIGATOIRE - À CHANGER EN PRODUCTION =====

# Base de données PostgreSQL
# ⚠️ Générez un mot de passe fort : openssl rand -base64 32
DB_PASSWORD=CHANGEZ_MOI_mot_de_passe_tres_fort_ici

# Sécurité JWT
# ⚠️ Générez une clé secrète : openssl rand -base64 32  
JWT_SECRET=CHANGEZ_MOI_cle_secrete_jwt_32_caracteres_minimum

# ===== OPTIONNEL =====

# Domaine (géré automatiquement par Coolify)
DOMAIN=votre-domaine.com

# Fuseau horaire
TZ=Europe/Paris

# Mode de l'application
GIN_MODE=release
NODE_ENV=production

# ===== NOTES POUR COOLIFY =====

# 1. Dans Coolify → Environment Variables, ajoutez :
#    - DB_PASSWORD (secret)
#    - JWT_SECRET (secret)
#    - DOMAIN (si personnalisé)

# 2. Coolify génère automatiquement :
#    - Les URLs et certificats SSL
#    - La configuration réseau
#    - Les volumes persistants

# 3. Surveillance recommandée :
#    - Activez les logs Coolify
#    - Configurez les alertes
#    - Planifiez les backups

# 4. Ressources recommandées :
#    - CPU : 1 vCPU minimum
#    - RAM : 1GB minimum
#    - Storage : 10GB minimum

# ===== GÉNÉRATION DES SECRETS =====

# Pour générer DB_PASSWORD :
# openssl rand -base64 32

# Pour générer JWT_SECRET :
# openssl rand -base64 32

# Ou utiliser un générateur en ligne sécurisé

# ===== VÉRIFICATION POST-DÉPLOIEMENT =====

# 1. Vérifiez l'accès : https://votre-domaine.com
# 2. Test de login : admin@airboard.com / admin123
# 3. Vérifiez les logs : Coolify → Logs
# 4. Test health check : https://votre-domaine.com/health